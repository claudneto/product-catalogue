/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "paths": {
      "shared": ["./projects/shared/src/public-api.ts"],
      "@br/environments/*": ["projects/br/src/environments/*"],
      "@br/core/*": ["projects/br/src/app/core/*"],
      "@br/features/*": ["projects/br/src/app/features/*"],
      "@shared/components/*": ["projects/shared/lib/components"],
      "@shared/models/*": ["projects/shared/lib/models"],
      "@shared/services/*": ["projects/shared/lib/services"],
      "@shared/utils/*": ["projects/shared/lib/utils"]
    },
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/br/tsconfig.app.json"
    },
    {
      "path": "./projects/br/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared/tsconfig.spec.json"
    }
  ]
}
